    "tap-trade": "bun run --cwd examples/tap-trade dev"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flash-trade/examples-v2"
  }
}
