{
  "name": "flash-magicblock-starter",
  "private": true,
  "description": "Perps at 50 ms \u2014 the official starter for building on Flash Trade's MagicBlock layer.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "hello": "bun run packages/flash-v2/src/hello.ts",
    "lifecycle": "bun run packages/flash-v2/src/lifecycle.ts",
