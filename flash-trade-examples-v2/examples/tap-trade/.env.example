# tap-trade — copy to .env.local and fill in ONE thing: your RPC key.
#   cp .env.example .env.local
#
# Flash Trade V2 runs on Solana MAINNET (real funds — start small).

NEXT_PUBLIC_FLASH_NETWORK=mainnet

# ── RPC ───────────────────────────────────────────────────────────────────────
# Base-chain RPC (setup / deposit / withdraw). Use your own CORS-friendly RPC —
# a FREE key from helius.dev / triton.one / quicknode.com. This URL ships in the
# browser bundle, so use a DOMAIN-RESTRICTED key.
NEXT_PUBLIC_BASE_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
# Ephemeral Rollup RPC (trading) — serves CORS, called directly from the browser.
NEXT_PUBLIC_ER_RPC=https://flash.magicblock.xyz

# Override the hosted Flash V2 API (rarely needed).
# NEXT_PUBLIC_FLASH_API_BASE=https://flashapi.trade/v2
