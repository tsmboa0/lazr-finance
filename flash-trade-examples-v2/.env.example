# Flash V2 starter — copy to .env. Defaults work immediately. MAINNET = real funds.

# Hosted Flash V2 API.
FLASH_V2_BASE_URL=https://flashapi.trade/v2

# Ephemeral Rollup RPC — TRADING transactions go here.
ER_RPC_URL=https://flash.magicblock.xyz

# Base-chain Solana RPC — SETUP + WITHDRAWAL transactions go here.
# The public RPC rate-limits; use your own keyed RPC (Helius/Triton) for anything real.
BASE_RPC_URL=https://api.mainnet-beta.solana.com

# Only needed to sign + submit (lifecycle --submit). THROWAWAY wallet, small funds. Never commit.
# KEYPAIR_PATH=~/.config/solana/throwaway.json
